rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    function isValidUserSettingsUpdate(data) {
      return (!data.keys().hasAny(['payPeriodStartDay']) || data.payPeriodStartDay is number)
          && (!data.keys().hasAny(['otDays']) || (data.otDays is list && data.otDays.size() <= 7))
          && (!data.keys().hasAny(['defaultStartTime']) || (data.defaultStartTime is string && data.defaultStartTime.size() <= 10))
          && (!data.keys().hasAny(['defaultEndTime']) || (data.defaultEndTime is string && data.defaultEndTime.size() <= 10))
          && (!data.keys().hasAny(['defaultBreakMinutes']) || (data.defaultBreakMinutes is number || data.defaultBreakMinutes is string))
          && (!data.keys().hasAny(['lang']) || (data.lang is string && data.lang.size() <= 5))
          && (!data.keys().hasAny(['isDarkMode']) || data.isDarkMode is bool)
          && (!data.keys().hasAny(['reminderTime']) || (data.reminderTime is string && data.reminderTime.size() <= 10))
          && (!data.keys().hasAny(['calendarViewMode']) || (data.calendarViewMode is string && data.calendarViewMode.size() <= 10))
          && (!data.keys().hasAny(['hourlyRate']) || (data.hourlyRate is number || data.hourlyRate == null))
          && (!data.keys().hasAny(['dailyStandardHours']) || (data.dailyStandardHours is number || data.dailyStandardHours == null));
    }

    function isValidLog(data, userId) {
      return data.keys().hasAll(['id', 'userId', 'date', 'startTime', 'endTime', 'breakMinutes', 'totalHours'])
          && data.id is string && data.id.size() <= 128
          && data.userId == userId
          && data.date is string && data.date.size() <= 20
          && data.startTime is string && data.startTime.size() <= 10
          && data.endTime is string && data.endTime.size() <= 10
          && (data.breakMinutes is number || data.breakMinutes is string)
          && (data.totalHours is number || data.totalHours is string)
          && (!data.keys().hasAny(['timestamp']) || data.timestamp is number)
          && (!data.keys().hasAny(['createdAt']) || data.createdAt is string)
          && (!data.keys().hasAny(['overtimeHours']) || data.overtimeHours is number || data.overtimeHours is string)
          && (!data.keys().hasAny(['isDayOff']) || data.isDayOff is bool)
          && (!data.keys().hasAny(['isWholeDayOT']) || data.isWholeDayOT is bool);
    }

    match /users/{userId} {
      match /settings/{settingId} {
        allow get: if isOwner(userId) && isValidId(settingId);
        allow create, update: if isOwner(userId) && isValidId(settingId) && isValidUserSettingsUpdate(incoming());
      }

      match /logs/{logId} {
        allow get: if isOwner(userId) && isValidId(logId);
        allow list: if isOwner(userId) && resource.data.userId == userId;
        allow create: if isOwner(userId) && isValidId(logId) && isValidLog(incoming(), userId);
        allow update: if isOwner(userId) && isValidId(logId) && isValidLog(incoming(), userId);
        allow delete: if isOwner(userId) && isValidId(logId);
      }
    }
  }
}
